# Copy to .env and edit. All settings are optional — defaults are permissive
# for a single-user self-host.

# Where downloaded files land. In Docker this is /data/downloads (a volume).
# VD_DOWNLOAD_DIR=./downloads

# Path to the built Vite frontend. Set in Docker; leave unset in dev.
# VD_FRONTEND_DIST=/app/frontend/dist

# Logging
# VD_LOG_LEVEL=INFO

# Concurrency
# VD_MAX_CONCURRENT_DOWNLOADS=3

# Per-download caps
# VD_MAX_FILESIZE_BYTES=8589934592   # 8 GiB
# VD_MAX_DURATION_SECONDS=21600      # 6 hours

# Job retention — completed/failed jobs older than TTL are evicted and their
# files unlinked. The cleanup loop runs every CLEANUP_INTERVAL_SECONDS.
# VD_JOB_TTL_SECONDS=21600           # 6 hours
# VD_CLEANUP_INTERVAL_SECONDS=900    # 15 minutes

# CORS — only matters in dev when the frontend runs on a separate origin.
# In production the backend serves the SPA itself, so leave this alone.
# VD_CORS_ORIGINS=["http://localhost:5173","http://localhost:4173"]
